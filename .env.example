# Окружение: development (dev) или production (prod)
APP_ENV=development

# Порт API-сервера (3001 для dev, 3002 для prod)
PORT=3001

# Скрипты npm задают эти переменные автоматически:
#   npm run dev          → APP_ENV=development, PORT=3001, UI на :5173
#   npm run prod         → APP_ENV=production, PORT=3002, UI на :3002
#   npm run prod:restart → сборка + prod
